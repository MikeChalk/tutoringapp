generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  password          String
  role              String   @default("CLIENT")
  cityId            String?
  signupToken       String?  @unique
  emailNotifications Boolean @default(true)
  smsNotifications  Boolean  @default(false)
  resetToken        String?  @unique
  resetTokenExpiry  DateTime?
  totpSecret        String?
totpEnabled       Boolean  @default(false)
  firstLoginAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tutor    Tutor?
  client   Client?
  accounts Account[]
  sessions Session[]
  city     City?    @relation(fields: [cityId], references: [id])

  @@index([cityId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Tutor {
  id                  String    @id @default(cuid())
  userId              String    @unique
  bio                 String?
  subjects            String    @default("")
  gradeLevels         String    @default("")
  tenure              String    @default("1ST_YEAR")
  onboardingStep      Int       @default(0)
  isActive            Boolean   @default(true)
  onboarded           Boolean   @default(false)
  onboardedAt         DateTime?
  cvToken             String?   @unique
  cvFilename          String?
  transcriptFilename  String?
  stripeConnectId     String?
  phone               String?
  currentStudies      String?
  highSchool          String?
  preferredFormat     String?
  borough             String?
  workExperience      String?
  activity            String    @default("Active")
  cvUploaded          Boolean   @default(false)
  transcriptUploaded  Boolean   @default(false)
  videoWatched        Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts        Contract[]
  hourLogs         HourLog[]
  projectTutors    ProjectTutor[]
  tutoringRequests TutoringRequest[] @relation("MatchedTutor")

  @@map("tutors")
}

model Client {
  id             String    @id @default(cuid())
  userId         String    @unique
  type           String    @default("PARENT")
  company        String?
  phone          String?
  address        String?
  province       String?
  country        String?
  postalCode     String?
  notes          String?
  tosAccepted    Boolean   @default(false)
  tosAcceptedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects         Project[]
  invoices         Invoice[]
  expenses         Expense[]
  tutoringRequests TutoringRequest[] @relation("RequestClient")
  convertedLeads   Lead[]            @relation("LeadConversion")
  schoolCycles     StudyHallCycle[]  @relation("CycleSchool")
  registrations    Registration[]    @relation("RegistrationParent")

  @@map("clients")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  subjects    String   @default("")
  projectType String   @default("STUDENT")
  school      String   @default("")
  gradeLevel  String   @default("ELEMENTARY")
  status      String   @default("IN_PROGRESS")
  clientId    String?
  cityId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  city          City?          @relation(fields: [cityId], references: [id])
  projectTutors ProjectTutor[]
  hourLogs      HourLog[]
  studyHallCycle StudyHallCycle?

  @@index([clientId])
  @@index([cityId])
  @@map("projects")
}

model ProjectTutor {
  id         String   @id @default(cuid())
  projectId  String
  tutorId    String
  assignedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tutor   Tutor   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([projectId, tutorId])
  @@index([tutorId])
  @@map("project_tutors")
}

model HourLog {
  id           String    @id @default(cuid())
  tutorId      String
  projectId    String
  date         DateTime
  hours        Float
  mode         String    @default("IN_PERSON")
  billingRate  Float     @default(0)
  tutorPayRate Float     @default(0)
  description  String?
  category     String?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tutor        Tutor         @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  expense      Expense?

  @@index([tutorId, date])
  @@index([projectId, date])
  @@map("hour_logs")
}

model Invoice {
  id          String    @id @default(cuid())
  number      String    @unique
  clientId    String?
  status      String    @default("DRAFT")
  totalAmount Float     @default(0)
  dueDate     DateTime
  invoiceDate DateTime?
  notes       String?
  sentAt      DateTime?
  paidAt      DateTime?
  paymentGateway String?
  subtotal    Float     @default(0)
  taxRate     Float     @default(0)
  taxAmount   Float     @default(0)
  discountCode     String?
  discountPct      Float     @default(0)
  discountAmount   Float     @default(0)
  receiptUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client  Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items   InvoiceItem[]
  registration Registration?

  @@index([clientId, status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  hourLogId   String?
  description String
  hours       Float   @default(0)
  rate        Float   @default(0)
  amount      Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  hourLog HourLog? @relation(fields: [hourLogId], references: [id], onDelete: SetNull)

  @@map("invoice_items")
}

model TutoringRequest {
  id                 String    @id @default(cuid())
  name               String
  email              String
  phone              String?
  subject            String
  description        String?
  preferredSchedule  String?
  studentName        String?
  gradeLevel         String?
  school             String?
  tutoringPreference String?
  address            String?
  discountCode       String?
  status             String    @default("NEW")
  matchedTutorId     String?
  clientId           String?
  cityId             String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  matchedTutor Tutor?  @relation("MatchedTutor", fields: [matchedTutorId], references: [id], onDelete: SetNull)
  client       Client? @relation("RequestClient", fields: [clientId], references: [id], onDelete: SetNull)
  city         City?   @relation(fields: [cityId], references: [id])

  @@index([status, createdAt])
  @@index([cityId])
  @@index([matchedTutorId])
  @@map("tutoring_requests")
}

model BillingRate {
  id          String @id @default(cuid())
  gradeLevel  String
  mode        String
  projectType String @default("STUDENT")
  rate        Float

  @@unique([gradeLevel, mode, projectType])
  @@map("billing_rates")
}

model PayScale {
  id          String @id @default(cuid())
  tenure      String
  gradeLevel  String
  mode        String
  projectType String @default("STUDENT")
  rate        Float

  @@unique([tenure, gradeLevel, mode, projectType])
  @@map("pay_scales")
}

model Contract {
  id        String    @id @default(cuid())
  tutorId   String
  type      String    @default("PRIVATE_TUTORING")
  yearLevel String    @default("1ST_YEAR")
  terms     String    @default("")
  rates     String    @default("{}")
  startDate DateTime
  endDate   DateTime
  signed      Boolean   @default(false)
  signedAt    DateTime?
  signedByName String?
  status      String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tutor Tutor @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId, status])
  @@map("contracts")
}

model ContractTemplate {
  id          String    @id @default(cuid())
  name        String
  type        String    @default("PRIVATE_TUTORING")
  yearLevel   String    @default("1ST_YEAR")
  startDate   DateTime?
  endDate     DateTime?
  terms       String    @default("")
  gradeLevels String    @default("")
  rates       String    @default("{}")
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("contract_templates")
}

model Expense {
  id              String   @id @default(cuid())
  description     String
  amount          Float
  category        String   @default("OTHER")
  date            DateTime @default(now())
  cityId          String?
  clientId        String?
  hourLogId       String?  @unique
  receiptFileName String?
  receiptUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  city    City?    @relation(fields: [cityId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  hourLog HourLog? @relation(fields: [hourLogId], references: [id], onDelete: SetNull)

  @@index([clientId, date])
  @@index([cityId, date])
  @@map("expenses")
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  profitPct Float    @default(30)
  createdAt DateTime @default(now())

  users            User[]
  projects         Project[]
  expenses         Expense[]
  leads            Lead[]
  tutoringRequests TutoringRequest[]
  studyHallCycles  StudyHallCycle[]

  @@map("cities")
}

model CompanySettings {
  id              String  @id @default("main")
  name            String  @default("J.A.S.S. Tutoring")
  email           String  @default("info@jasstutors.com")
  phone           String  @default("")
  address         String  @default("")
  website         String  @default("")
  taxNumber       String  @default("")
  invoicePrefix   String  @default("INV-")
  invoiceNotes    String  @default("Thank you for your business!")
  defaultTaxRate  Float   @default(0)
  stripeEnabled   Boolean @default(false)
  smsEnabled      Boolean @default(false)
  openaiEnabled   Boolean @default(false)
  emailEnabled    Boolean @default(true)
  payoutFrequency String  @default("manual")
  lastPayoutAt    DateTime?
  twilioSid       String  @default("")
  twilioToken     String  @default("")
  twilioFrom      String  @default("")
  openaiKey       String  @default("")
  stripeKey       String  @default("")
  resendKey       String  @default("")
  smtpHost        String  @default("")
  smtpPort        Int     @default(587)
  smtpUser        String  @default("")
  smtpPassword    String  @default("")

  @@map("company_settings")
}

model DiscountCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String   @default("")
  discountPct Float    @default(0)
  discountAmt Float    @default(0)
  isActive    Boolean  @default(true)
  maxUses     Int      @default(0)
  usedCount   Int      @default(0)
  cycleId     String?
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cycle StudyHallCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([cycleId])
  @@map("discount_codes")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  notes     String?
  status    String   @default("NEW")
  cityId    String?
  convertedToClientId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city               City?   @relation(fields: [cityId], references: [id])
  convertedToClient  Client? @relation("LeadConversion", fields: [convertedToClientId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([cityId])
  @@map("leads")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  trigger   String   @unique
  subject   String
  htmlBody  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  trigger   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("email_logs")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model StudyHallCycle {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  schoolClientId        String?
  projectId             String?   @unique
  cityId                String?
  yearLabel             String    @default("")
  cycleNumber           Int       @default(1)
  billingModel          String    @default("INDIVIDUAL")
  startDate             DateTime
  endDate               DateTime
  registrationOpen      DateTime?
  registrationClose     DateTime?
  preregistrationDeadline DateTime?
  preregistrationDiscount Float   @default(0)
  earlyBirdEnabled       Boolean  @default(false)
  earlyBirdPct           Float    @default(0)
  earlyBirdDeadline      DateTime?
  pricePerSession       Float     @default(0)
  dayOptions            String    @default("[]")
  gradeOptions          String    @default("[]")
  formConfig            String    @default("{}")
  introText             String    @default("")
  scheduleText          String    @default("")
  pricingText           String    @default("")
  termsText             String    @default("")
  photoReleaseText     String    @default("")
  status                String    @default("DRAFT")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  schoolClient  Client?          @relation("CycleSchool", fields: [schoolClientId], references: [id], onDelete: SetNull)
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  city          City?            @relation(fields: [cityId], references: [id])
  registrations Registration[]
  discountCodes DiscountCode[]

  @@index([schoolClientId])
  @@index([cityId])
  @@index([status])
  @@map("study_hall_cycles")
}

model Registration {
  id              String    @id @default(cuid())
  cycleId         String
  studentName     String
  grade           String?
  parentName      String
  parentEmail     String
  parentPhone     String
  firstLanguage   String?
  daySelections   String    @default("[]")
  sessionsCount   Int       @default(0)
  subtotal        Float     @default(0)
  childNotes      String?
  referrerName    String?
  discountCode    String?
  discountPct     Float     @default(0)
  discountAmount  Float     @default(0)
  preregDiscount  Float     @default(0)
  totalAmount     Float     @default(0)
  termsAccepted   Boolean   @default(false)
  termsSignature  String?
  photoRelease    String?
  clientId        String?
  invoiceId       String?   @unique
  status          String    @default("PENDING")
  confirmedAt     DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cycle   StudyHallCycle? @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  client  Client?         @relation("RegistrationParent", fields: [clientId], references: [id], onDelete: SetNull)
  invoice Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([cycleId, status])
  @@index([clientId])
  @@index([parentEmail])
  @@map("registrations")
}
